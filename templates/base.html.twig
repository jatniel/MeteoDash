<!DOCTYPE html>
<html lang="{% block lang %}en{% endblock %}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>{% block title %}MeteoDash — Instant Weather Dashboard{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}Check current weather and hourly forecast for any city in the world. Temperature, humidity, wind speed and more - instantly.{% endblock %}">
        <meta name="robots" content="{% block robots %}index, follow{% endblock %}">
        <meta name="author" content="Jatniel Guzmán">
        <meta name="theme-color" content="#4a90d9">

        <!-- Open Graph -->
        <meta property="og:type" content="website">
        <meta property="og:site_name" content="MeteoDash">
        <meta property="og:title" content="{% block og_title %}MeteoDash — Instant Weather Dashboard{% endblock %}">
        <meta property="og:description" content="{% block og_description %}Check current weather and hourly forecast for any city in the world.{% endblock %}">

        <!-- Preconnect for weather icons -->
        <link rel="preconnect" href="https://openweathermap.org">

        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🌤️</text></svg>">

        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <div class="container">
            {% block body %}{% endblock %}
        </div>

        {% block javascripts %}{% endblock %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    </body>
</html>
